{{<index.html.mustache}}
  {{$content}}

    {{<primitives/h1}}
      {{$content}}
        {{labels.orderConfirmationToBrukerTitle}}
      {{/content}}
    {{/primitives/h1}}

    {{<primitives/container}}
      {{$content}}
        {{<primitives/paragraph}}
          {{$content}}
            {{^innsynskravList}}
              {{labels.orderConfirmationToBrukerEmpty}}
            {{/innsynskravList}}
          {{/content}}
        {{/primitives/paragraph}}
      {{/content}}
    {{/primitives/container}}

    {{^innsynskravList.isEmpty}}
      {{<primitives/container}}
        {{$content}}
          {{<primitives/paragraph}}
            {{$content}}{{labels.orderConfirmationToBrukerIntro}}{{/content}}
          {{/primitives/paragraph}}

            {{#innsynskravGroups}}
              {{<primitives/h2}}
                {{$content}}
                  {{#virksomhet}}{{navn}}{{/virksomhet}}
                {{/content}}
              {{/primitives/h2}}
              {{#virksomhet}}{{#innsynskravEpost}}
                {{<primitives/container}}
                  {{$content}}
                    {{<primitives/paragraph}}
                      {{$content}}
                        {{<primitives/link}}
                          {{$link}}mailto:{{innsynskravEpost}}{{/link}}
                          {{$content}}{{innsynskravEpost}}{{/content}}
                        {{/primitives/link}}
                      {{/content}}
                    {{/primitives/paragraph}}
                  {{/content}}
                {{/primitives/container}}
              {{/innsynskravEpost}}{{/virksomhet}}

            {{#dokumenter}}
              {{<primitives/container}}
                {{$content}}
                  <table cellspacing="0" cellpadding="0" border="0" width="100%" style="border-bottom: 1px solid #eeeeee;">
                    <tr class="es-mobile-stack">
                      <td class="es-mobile-label" style="padding: 10px 0 4px; width: 25%; vertical-align: top;">
                        {{labels.orderConfirmationToBrukerCaseTitleLabel}}
                      </td>
                      <td class="es-mobile-value" style="padding: 10px 0 4px; word-break: break-word;">
                        {{<primitives/link}}
                          {{$link}}{{baseUrl}}/saksmappe?id={{journalpost.saksmappe.legacyIri}}{{/link}}
                          {{$content}}{{journalpost.saksmappe.offentligTittelSensitiv}}{{/content}}
                        {{/primitives/link}}
                      </td>
                    </tr>
                    <tr class="es-mobile-stack">
                      <td class="es-mobile-label" style="padding: 0 0 4px; width: 25%; vertical-align: top;">
                        {{labels.orderConfirmationToBrukerJournalTitleLabel}}
                      </td>
                      <td class="es-mobile-value" style="padding: 0 0 4px; word-break: break-word;">
                        {{<primitives/link}}
                          {{$link}}{{baseUrl}}/saksmappe?id={{journalpost.saksmappe.legacyIri}}&jid={{journalpost.legacyIri}}{{/link}}
                          {{$content}}{{journalpost.offentligTittelSensitiv}}{{/content}}
                        {{/primitives/link}}
                      </td>
                    </tr>
                    <tr class="es-mobile-stack">
                      <td class="es-mobile-label" style="padding: 0 0 4px; width: 25%; vertical-align: top;">
                        {{labels.orderConfirmationToBrukerDocumentNumberLabel}}
                      </td>
                      <td class="es-mobile-value" style="padding: 0 0 4px;">{{journalpost.journalpostnummer}}</td>
                    </tr>
                    <tr class="es-mobile-stack">
                      <td class="es-mobile-label" style="padding: 0 0 10px; width: 25%; vertical-align: top;">
                        {{labels.orderConfirmationToBrukerCaseNumberLabel}}
                      </td>
                      <td class="es-mobile-value" style="padding: 0 0 10px;">{{journalpost.saksmappe.saksaar}}/{{journalpost.saksmappe.sakssekvensnummer}}</td>
                    </tr>
                  </table>
                {{/content}}
              {{/primitives/container}}
            {{/dokumenter}}
          {{/innsynskravGroups}}

        {{/content}}
      {{/primitives/container}}
    {{/innsynskravList.isEmpty}}

    {{^isAnonymous}}
      {{<primitives/container}}
        {{$content}}
          {{<primitives/button}}
            {{$link}}{{baseUrl}}/minside/innsynskrav{{/link}}
            {{$label}}{{labels.orderConfirmationToBrukerActionLabel}}{{/label}}
          {{/primitives/button}}
        {{/content}}
      {{/primitives/container}}
    {{/isAnonymous}}

    {{<primitives/container}}
      {{$content}}
        {{<primitives/paragraph}}
          {{$content}}{{ labels.orderConfirmationToBrukerOutro }}{{/content}}
        {{/primitives/paragraph}}
      {{/content}}
    {{/primitives/container}}

  {{/content}}
{{/index.html.mustache}}
